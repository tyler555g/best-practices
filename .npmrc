# Enforce lockfile — fail if package.json and lockfile are out of sync (use `npm ci` in CI)
# See: https://cheatsheetseries.owasp.org/cheatsheets/NPM_Security_Cheat_Sheet.html#2-enforce-the-lockfile
package-lock=true

# Audit level: fail on moderate or higher vulnerabilities in CI
# Run `npm audit` or `npm run audit:deps` to check
audit-level=moderate
